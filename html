async function simulateAudienceVotes(aiVerdict){
  const weights=aiVerdict==='HIRE'?[0.6,0.3,0.1]:aiVerdict==='MAYBE'?[0.3,0.4,0.3]:[0.1,0.3,0.6];
  for(const a of S.audienceMembers){
    await delay(200+Math.random()*400);
    const r=Math.random();
    const v=r<weights[0]?'hire':r<weights[0]+weights[1]?'maybe':'pass';
    const label=v==='hire'?'✓ Hire':v==='maybe'?'~ Maybe':'✗ Pass';
    const el=document.getElementById(`avv-${uid(a.name)}`);
    if(el){el.textContent=label;el.className=`av-verdict ${v}`;}
    a.verdict=v;
  }
}

