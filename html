// ── TEXT TO SPEECH (AI reads question / feedback) ──
function speakText(text, ctx) {
  if (!VOICE.supportsTTS) return;
  VOICE.synthesis.cancel(); // stop any ongoing speech
  const utt = new SpeechSynthesisUtterance(text);
  utt.lang  = 'en-IN';
  utt.rate  = 0.95;
  utt.pitch = 1.0;

  // Pick a slightly different voice for AI interviewer
  const voices = VOICE.synthesis.getVoices();
  const preferred = voices.find(v => v.lang.startsWith('en') && v.name.toLowerCase().includes('male'))
                 || voices.find(v => v.lang.startsWith('en'))
                 || null;
  if (preferred) utt.voice = preferred;

  if (ctx === 'iv') {
    const chip = document.getElementById('ai-speaking-chip');
    if (chip) chip.classList.add('visible');
    utt.onend = () => { if (chip) chip.classList.remove('visible'); };
    setVoiceStatus('iv', 'AI Speaking…', 'vs-speaking');
    utt.onend = () => {
      if (chip) chip.classList.remove('visible');
      setVoiceStatus('iv', 'Your turn', '');
    };
  }
  VOICE.synthesis.speak(utt);
}

// ── Read AI feedback aloud after evaluation ──
function speakIVFeedback(review) {
  if (!VOICE.ivMode || !VOICE.supportsTTS) return;
  const text = `Your score is ${review.ai_score} out of 10. Verdict: ${review.verdict}. Strength: ${review.strengths}. To improve: ${review.improvements}`;
  speakText(text, 'iv');
}

