const GUIDE_TOTAL = 6;

function openGuide(){
  document.getElementById('guide-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeGuide(){
  document.getElementById('guide-overlay').classList.remove('open');
  document.body.style.overflow = '';
}

function switchGuideTab(idx){
  // deactivate old
  document.getElementById('gpanel-' + currentGuideTab).classList.remove('active');
  document.getElementById('gtab-'   + currentGuideTab).classList.remove('active');
  document.getElementById('gdot-'   + currentGuideTab).classList.remove('active');
  // activate new
  currentGuideTab = idx;
  document.getElementById('gpanel-' + idx).classList.add('active');
  document.getElementById('gtab-'   + idx).classList.add('active');
  document.getElementById('gdot-'   + idx).classList.add('active');
  // update nav buttons
  document.getElementById('gnb-prev').disabled = idx === 0;
  document.getElementById('gnb-prev').style.opacity = idx === 0 ? '0.3' : '1';
  const nextBtn = document.getElementById('gnb-next');
  if(idx === GUIDE_TOTAL - 1){
    nextBtn.textContent = 'Got It ✓';
    nextBtn.onclick = closeGuide;
  } else {
    nextBtn.textContent = 'Next →';
    nextBtn.onclick = () => guideNav(1);
  }
}

function guideNav(dir){
  const next = Math.max(0, Math.min(GUIDE_TOTAL - 1, currentGuideTab + dir));
  switchGuideTab(next);
}

// close on Escape key
document.addEventListener('keydown', e => {
  if(e.key === 'Escape') closeGuide();
});

// init button state
document.getElementById('gnb-prev').style.opacity = '0.3';
document.getElementById('gnb-prev').disabled = true;

// ── Voice: auto-read question when IV voice mode is ON ──
const __origRenderIVQ = renderIVQuestion;
renderIVQuestion = function() {
  __origRenderIVQ();
  // reset mic button state
  const btn = document.getElementById('iv-mic-btn');
  if (btn) { btn.textContent = '🎤'; btn.classList.remove('recording'); }
  if (VOICE.ivRecording) stopIVMic();
  setVoiceStatus('iv', 'Ready');

  // Read question aloud if voice mode on
  if (VOICE.ivMode && S.ivQs[S.currentIQ]) {
    setTimeout(() => speakText('Question ' + (S.currentIQ+1) + ': ' + S.ivQs[S.currentIQ].q, 'iv'), 400);
  }
};

// ── Voice: speak feedback after submitAnswer ──
const __origSubmitAnswer = submitAnswer;
submitAnswer = async function() {
  // Stop mic if running
  if (VOICE.ivRecording) stopIVMic();
  await __origSubmitAnswer();
  // After review renders, read feedback aloud
  if (VOICE.ivMode && S.ivAIReviews.length) {
    setTimeout(() => speakIVFeedback(S.ivAIReviews[S.ivAIReviews.length - 1]), 600);
  }
};

// ── Voice: clean up on restart ──
const __origRestartGame = restartGame;
restartGame = function() {
  stopAllVoice();
  VOICE.gdMode = false;
  VOICE.ivMode = false;
  // reset GD voice UI
  const gdPill = document.getElementById('gd-voice-toggle');
  const gdBar  = document.getElementById('gd-voice-bar');
  const gdNote = document.getElementById('gd-voice-notice');
  if(gdPill) gdPill.classList.remove('active');
  if(gdBar)  gdBar.style.display = 'none';
  if(gdNote) gdNote.classList.remove('show');
  // reset IV voice UI
  const ivPill = document.getElementById('iv-voice-toggle');
  const ivBar  = document.getElementById('iv-voice-bar');
  const ivNote = document.getElementById('iv-voice-notice');
  if(ivPill) ivPill.classList.remove('active');
  if(ivBar)  ivBar.style.display = 'none';
  if(ivNote) ivNote.classList.remove('show');
  __origRestartGame();
};

// Pre-load TTS voices (needed for some browsers)
if (VOICE.supportsTTS) {
  window.speechSynthesis.onvoiceschanged = () => { window.speechSynthesis.getVoices(); };
}
</script>
