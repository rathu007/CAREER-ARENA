<script>
// ════════════════════════════════════════════
//  QUESTION BANK (40 questions, 4 categories)
// ════════════════════════════════════════════
const QUESTION_BANK = [
  // LOGICAL REASONING
  {q:"If all Bloops are Razzles and all Razzles are Lazzles, are all Bloops definitely Lazzles?",options:["Yes","No","Cannot determine","Only some"],answer:0,explanation:"Transitive: Bloop→Razzle→Lazzle.",cat:"Logical Reasoning"},
  {q:"What comes next: 2, 6, 12, 20, 30, ?",options:["40","42","44","48"],answer:1,explanation:"Differences 4,6,8,10,12 → next is 42.",cat:"Logical Reasoning"},
  {q:"Find the odd one out: Violin, Guitar, Flute, Sitar",options:["Violin","Guitar","Flute","Sitar"],answer:2,explanation:"Flute is a wind instrument; the rest are string instruments.",cat:"Logical Reasoning"},
  {q:"How many times does digit '3' appear from 1 to 50?",options:["5","10","15","6"],answer:2,explanation:"3,13,23,30-39(11 times),43 → 15 total.",cat:"Logical Reasoning"},
  {q:"If A > B, B > C, and C > D, which is smallest?",options:["A","B","C","D"],answer:3,explanation:"D is the smallest by transitive comparison.",cat:"Logical Reasoning"},
  {q:"Pointing to a photo a man says 'His mother is my mother's only daughter.' Who is in the photo?",options:["His nephew","His son","His uncle","His brother"],answer:1,explanation:"My mother's only daughter = me (woman). The man in photo is her son.",cat:"Logical Reasoning"},
  {q:"Complete the series: Z, X, V, T, R, ?",options:["P","Q","O","S"],answer:0,explanation:"Skipping every alternate letter backward: Z X V T R P.",cat:"Logical Reasoning"},
  {q:"If ROSE is coded as 6821, how is SORE coded?",options:["8216","2168","8261","2618"],answer:0,explanation:"R=6,O=8,S=2,E=1 → S=2,O=8,R=6,E=1 → 8216... wait: S=2,O=8,R=6,E=1 = 2861. Correct: 2861 but nearest = 8216 swap S and O: S(2),O(8),R(6),E(1)=2861.",options:["2861","8621","6218","1268"],answer:0,explanation:"S=2,O=8,R=6,E=1 → SORE = 2861.",cat:"Logical Reasoning"},
  {q:"A is to the east of B. C is to the north of B. D is to the south of C. Where is D relative to B?",options:["East","North","South","Cannot determine"],answer:3,explanation:"D is south of C (which is north of B), D's exact position relative to B cannot be determined without distance info.",cat:"Logical Reasoning"},
  {q:"What is the next term: 1, 1, 2, 3, 5, 8, 13, ?",options:["18","20","21","22"],answer:2,explanation:"Fibonacci sequence: 8+13=21.",cat:"Logical Reasoning"},

  // NUMERICAL APTITUDE
  {q:"A train travels 60 km in 45 minutes. What is its speed in km/h?",options:["75","80","90","100"],answer:1,explanation:"60÷(45/60) = 80 km/h.",cat:"Numerical"},
  {q:"If a product costs ₹540 at 10% profit, what was the cost price?",options:["₹486","₹490","₹494","₹500"],answer:1,explanation:"CP = 540/1.10 = ₹490.9 ≈ ₹490.",cat:"Numerical"},
  {q:"A can do a job in 10 days, B in 15 days. Together, how many days?",options:["5","6","7","8"],answer:1,explanation:"Combined rate = 1/10+1/15 = 1/6, so 6 days.",cat:"Numerical"},
  {q:"What percent of 120 is 30?",options:["20%","25%","30%","35%"],answer:1,explanation:"30/120 × 100 = 25%.",cat:"Numerical"},
  {q:"Simple interest on ₹5000 at 8% per annum for 3 years?",options:["₹1000","₹1200","₹1500","₹1800"],answer:1,explanation:"SI = 5000×8×3/100 = ₹1200.",cat:"Numerical"},
  {q:"The average of 5 numbers is 20. If one number is removed, the average becomes 15. What was the removed number?",options:["35","40","45","50"],answer:1,explanation:"Sum=100, new sum=60, removed=100-60=40.",cat:"Numerical"},
  {q:"A man walks 5km north, then 12km east. How far is he from start?",options:["13km","15km","17km","7km"],answer:0,explanation:"√(5²+12²)=√169=13km.",cat:"Numerical"},
  {q:"Find the LCM of 12 and 18.",options:["24","36","48","72"],answer:1,explanation:"LCM(12,18) = 36.",cat:"Numerical"},
  {q:"A 20% discount is given on ₹800. What is the sale price?",options:["₹600","₹620","₹640","₹660"],answer:2,explanation:"800×0.80 = ₹640.",cat:"Numerical"},
  {q:"If 3 men can do a job in 4 days, how many days for 6 men?",options:["1","2","3","8"],answer:1,explanation:"3×4=12 man-days; 12÷6=2 days.",cat:"Numerical"},

  // VERBAL ABILITY
  {q:"Choose the word most similar to 'EPHEMERAL':",options:["Eternal","Transient","Significant","Robust"],answer:1,explanation:"Ephemeral = short-lived = Transient.",cat:"Verbal Ability"},
  {q:"Select the antonym of 'BENEVOLENT':",options:["Kind","Generous","Malevolent","Charitable"],answer:2,explanation:"Malevolent = wishing harm, opposite of benevolent.",cat:"Verbal Ability"},
  {q:"Choose the correctly spelled word:",options:["Accomodate","Accommodate","Acommodate","Acomodate"],answer:1,explanation:"Accommodate has double 'c' and double 'm'.",cat:"Verbal Ability"},
  {q:"Synonym of 'VERBOSE':",options:["Silent","Wordy","Concise","Mysterious"],answer:1,explanation:"Verbose = using more words than needed = Wordy.",cat:"Verbal Ability"},
  {q:"'Burning the midnight oil' means:",options:["Setting things on fire","Working late into the night","Wasting resources","Being careless"],answer:1,explanation:"This idiom means working or studying late at night.",cat:"Verbal Ability"},
  {q:"Choose the antonym of 'LUCID':",options:["Clear","Bright","Obscure","Transparent"],answer:2,explanation:"Lucid=clear; Obscure=unclear, its antonym.",cat:"Verbal Ability"},
