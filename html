  document.getElementById('btn-submit-iv').style.color='#fff';
}

function renderAudiencePanel(){
  document.getElementById('audience-vote-list').innerHTML=S.audienceMembers.map(a=>
    `<div class="audience-item" id="av-${uid(a.name)}">
      <div class="av-ava" style="background:${a.color}22;color:${a.color}">${a.initial}</div>
      <div class="av-name">${a.name}</div>
      <div class="av-verdict thinking" id="avv-${uid(a.name)}">Watching…</div>
    </div>`).join('');
}

function updateIVDualPanel(){
  const count=S.ivAIReviews.length||1;
  const aiAvg=S.ivAIReviews.length? Math.round(S.ivAITotal/S.ivAIReviews.length*10)/10:0;
  const audAvg=S.ivAIReviews.length? Math.round(S.ivAudTotal/S.ivAIReviews.length*10)/10:0;
  const comb=S.ivAIReviews.length? Math.round((aiAvg*0.5+audAvg*0.5)*10)/10:0;

  document.getElementById('iv-ai-score').textContent=S.ivAIReviews.length?`${aiAvg}/10`:'—';
  document.getElementById('iv-aud-score').textContent=S.ivAIReviews.length?`${audAvg}/10`:'—';
  document.getElementById('iv-comb-num').textContent=S.ivAIReviews.length?comb:'—';

  const verdictEl=document.getElementById('iv-comb-verdict');
  if(S.ivAIReviews.length){
    const v=comb>=7?'HIRE':comb>=5?'MAYBE':'PASS';
    const vc=comb>=7?'cv-advance':comb>=5?'cv-borderline':'cv-eliminated';
    verdictEl.textContent=v;
    verdictEl.className=`iv-comb-verdict ${vc}`;
  }
}

async function submitAnswer(){
  const answer=document.getElementById('iv-answer').value.trim();
  if(!answer){document.getElementById('iv-answer').style.borderColor='var(--accent2)';return;}
  document.getElementById('iv-answer').disabled=true;
  document.getElementById('btn-submit-iv').disabled=true;
  S.ivAnswers.push(answer);

  const reviewArea=document.getElementById('iv-review-area');
  reviewArea.innerHTML=`<div class="ai-thinking">Evaluating your answer <div class="ai-dots"><span></span><span></span><span></span></div></div>`;

  const q=S.ivQs[S.currentIQ];
  const reviewJson=await callClaudeJSON(
    `You are a senior interviewer. Evaluate this answer for a career competition.
Question: "${q.q}"
Category: ${q.cat}
Answer: "${answer}"
Return JSON: { "verdict": "HIRE"|"MAYBE"|"PASS", "ai_score": 1-10, "strengths": string (≤15 words), "improvements": string (≤15 words) }`,
    'Return only valid JSON.'
  );
  const review=reviewJson||{verdict:'MAYBE',ai_score:6,strengths:'Clear and structured response.',improvements:'Add specific examples and metrics.'};
  S.ivAIReviews.push(review);
  S.ivAITotal+=review.ai_score;

  // Audience scoring
  const audScore=Math.max(1,Math.min(10,review.ai_score+(Math.random()*3-1.5)));
  const audRounded=Math.round(audScore*10)/10;
  S.ivAudTotal+=audRounded;

  const verdictClass=review.verdict==='HIRE'?'hire':review.verdict==='MAYBE'?'maybe':'pass';

  reviewArea.innerHTML=`
    <div class="ai-review-block">
      <div class="air-header">
        <div class="air-source">🤖 AI Interviewer</div>
        <div class="air-verdict ${verdictClass}">${review.verdict}</div>
        <div class="air-score">${review.ai_score}/10</div>
      </div>
      <div class="air-text">
        <strong style="color:var(--accent3)">✓ Strengths:</strong> ${review.strengths}<br>
        <strong style="color:var(--accent2)">↑ Improve:</strong> ${review.improvements}
      </div>
    </div>
    <div class="ai-review-block" style="border-color:var(--accent3)22">
      <div class="air-header">
        <div class="air-source">👥 Audience Rating</div>
        <div class="air-verdict ${audRounded>=7?'hire':audRounded>=5?'maybe':'pass'}">${audRounded>=7?'HIRE':audRounded>=5?'MAYBE':'PASS'}</div>
        <div class="air-score">${audRounded}/10</div>
      </div>
      <div class="air-text">Audience voted based on clarity, confidence, and relevance.</div>
    </div>`;

  await simulateAudienceVotes(review.verdict);
  updateIVDualPanel();

  S.currentIQ++;
  if(S.currentIQ<S.ivQs.length){
    document.getElementById('btn-submit-iv').disabled=false;
    document.getElementById('btn-submit-iv').textContent='Next Question →';
    document.getElementById('btn-submit-iv').onclick=()=>{ renderIVQuestion(); };
  } else {
    document.getElementById('btn-submit-iv').disabled=false;
    document.getElementById('btn-submit-iv').textContent='See Final Results 🏆';
    document.getElementById('btn-submit-iv').style.background='var(--accent3)';
    document.getElementById('btn-submit-iv').style.color='#080810';
    document.getElementById('btn-submit-iv').onclick=showFinalResults;
  }
}

async function simulateAudienceVotes(aiVerdict){
  const weights=aiVerdict==='HIRE'?[0.6,0.3,0.1]:aiVerdict==='MAYBE'?[0.3,0.4,0.3]:[0.1,0.3,0.6];
  for(const a of S.audienceMembers){
    await delay(200+Math.random()*400);
    const r=Math.random();
    const v=r<weights[0]?'hire':r<weights[0]+weights[1]?'maybe':'pass';
    const label=v==='hire'?'✓ Hire':v==='maybe'?'~ Maybe':'✗ Pass';
    const el=document.getElementById(`avv-${uid(a.name)}`);
    if(el){el.textContent=label;el.className=`av-verdict ${v}`;}
    a.verdict=v;
  }
}

// ════════════════════════════════════════════
//  FINAL RESULTS
// ════════════════════════════════════════════
function showFinalResults(){
  const aiAvg=S.ivAIReviews.length?S.ivAITotal/S.ivAIReviews.length:5;
  const audAvg=S.ivAIReviews.length?S.ivAudTotal/S.ivAIReviews.length:5;
  const quizScore=(S.score/10)*10;
  const gdAI=S.gdAIScores[S.playerName]?.score||5;
  const gdAud=S.gdAudScores[S.playerName]||5;

  const playerFinal=Math.round((quizScore*0.25 + (gdAI+gdAud)/2*0.35 + (aiAvg+audAvg)/2*0.4)*10)/10;

  const aiScores=S.aiPlayers.map(p=>{
    const gAI=S.gdAIScores[p.name]?.score||5;
    const gAud=S.gdAudScores[p.name]||5;
    const iv=Math.random()*4+5;
    return {name:p.name,score:Math.round(((gAI+gAud)/2*0.6+iv*0.4)*10)/10};
  });
  const allScores=[{name:S.playerName,score:playerFinal},...aiScores].sort((a,b)=>b.score-a.score);
  const winner=allScores[0];

  document.getElementById('final-winner-name').textContent=winner.name+(winner.name===S.playerName?' 🎉':'');
  const medals=['gold','silver','bronze'],icons=['🥇','🥈','🥉'];
  document.getElementById('final-podium').innerHTML=allScores.slice(0,3).map((p,i)=>
    `<div class="podium-card ${medals[i]}">
      <div class="podium-rank">${icons[i]}</div>
      <div class="podium-pname">${p.name}</div>
      <div class="podium-breakdown">Overall: ${p.score}/10</div>
    </div>`).join('');

  if(winner.name===S.playerName) launchConfetti();
  showScreen('screen-final');
}

// ════════════════════════════════════════════
//  UTILS
// ════════════════════════════════════════════
function uid(name){ return name.replace(/[^a-zA-Z0-9]/g,'_'); }

function launchConfetti(){
  const c=document.getElementById('confetti-container'); c.innerHTML='';
  const cols=['#f5c518','#00e5a0','#ff4d4d','#4d9fff','#ff9f4d','#fff'];
  for(let i=0;i<90;i++){
    const p=document.createElement('div'); p.className='confetti-piece';
    p.style.left=Math.random()*100+'vw';
    p.style.background=cols[Math.floor(Math.random()*cols.length)];
    p.style.borderRadius=Math.random()>0.5?'50%':'0';
    p.style.animationDuration=(2+Math.random()*3)+'s';
    p.style.animationDelay=Math.random()*2+'s';
    c.appendChild(p);
  }
  setTimeout(()=>c.innerHTML='',6000);
}

function restartGame(){
  clearInterval(S.timerInterval); clearInterval(S.gdTimerInterval); clearInterval(S.speakTimerInterval);
  Object.assign(S,{playerName:'',quizQs:[],currentQ:0,score:0,passed:false,gdTopic:'',gdSpeech:'',aiPlayers:[],aiSpeeches:{},gdAIScores:{},gdAudScores:{},gdVotes:{},ivQs:[],currentIQ:0,ivAnswers:[],ivAIReviews:[],ivAITotal:0,ivAudTotal:0,audienceMembers:[]});
  document.getElementById('player-name-input').value='';
  showScreen('screen-lobby');
}

document.getElementById('player-name-input').addEventListener('keydown',e=>{ if(e.key==='Enter')startGame(); });
</script>
</body>
