async function scheduleAISpeeches(){
  for(let i=0;i<S.aiPlayers.length;i++){
    const p=S.aiPlayers[i];
    await delay(1200+i*600);
    setPlayerStatus(p.name,'Speaking...','speaking');
    document.getElementById(`pr-${uid(p.name)}`)?.classList.add('speaking');
    const speech=await generateAISpeech(p.name);
    S.aiSpeeches[p.name]=speech;
    appendSpeech(p,speech);
    setPlayerStatus(p.name,'Done','done');
    document.getElementById(`pr-${uid(p.name)}`)?.classList.remove('speaking');
    await delay(500);
  }
}

async function generateAISpeech(name){
  return await callClaude(
    `You are ${name}, a confident candidate in a group discussion on: "${S.gdTopic}". Give a strong 60-second speech (~110 words). Be opinionated and structured. Start immediately with your point.`,
    'Return only the speech text, no extra labels.'
  );
}

