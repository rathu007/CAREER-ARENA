async function runGDAIScoring(){
  // Score all players including user via Claude
  const allPlayers = [{name:S.playerName,speech:S.gdSpeech},...S.aiPlayers.map(p=>({name:p.name,speech:S.aiSpeeches[p.name]||'…'}))];
  const prompt=`You are a strict GD evaluator. Score each speaker for this GD topic: "${S.gdTopic}". 
Speeches:
${allPlayers.map(p=>`${p.name}: "${p.speech.substring(0,200)}"`).join('\n')}
Return JSON array. Each object: { "name": string, "score": number 1-10, "verdict": "Strong"|"Average"|"Weak", "comment": string (max 15 words) }`;
  const json = await callClaudeJSON(prompt,'Return only valid JSON array, no markdown.');
  const results = json || allPlayers.map(p=>({name:p.name,score:Math.floor(Math.random()*4)+5,verdict:'Average',comment:'Reasonable arguments presented.'}));

  results.forEach(r=>{ S.gdAIScores[r.name]=r; });

  // Generate audience scores (simulate crowd ratings)
  allPlayers.forEach(p=>{
    const base=S.gdAIScores[p.name]?.score||6;
    const audScore=Math.max(1,Math.min(10,base+(Math.random()*3-1.5)));
    S.gdAudScores[p.name]=Math.round(audScore*10)/10;
  });

  renderGDDualScores(allPlayers);
}

function renderGDDualScores(allPlayers){
  const aiArea=document.getElementById('ai-gd-scores');
  const audArea=document.getElementById('aud-gd-scores');
  const combArea=document.getElementById('gd-combined-scores');

  aiArea.innerHTML=allPlayers.map(p=>{
    const r=S.gdAIScores[p.name]||{score:5};
    const pct=r.score*10;
    const isYou=p.name===S.playerName;
    const color=isYou?COLORS[3]:S.aiPlayers.find(a=>a.name===p.name)?.color||COLORS[0];
    return `<div class="score-row">
      <div class="score-name" style="color:${color}">${isYou?'You':p.name.split(' ')[0]}</div>
      <div class="score-bar-wrap"><div class="score-fill" style="width:${pct}%;background:${color}"></div></div>
      <div class="score-val">${r.score}/10</div>
    </div>`;
  }).join('');

  audArea.innerHTML=allPlayers.map(p=>{
    const s=S.gdAudScores[p.name]||5;
    const pct=s*10;
    const isYou=p.name===S.playerName;
    const color=isYou?COLORS[3]:S.aiPlayers.find(a=>a.name===p.name)?.color||COLORS[0];
    return `<div class="score-row">
      <div class="score-name" style="color:${color}">${isYou?'You':p.name.split(' ')[0]}</div>
      <div class="score-bar-wrap"><div class="score-fill" style="width:${pct*10}%;background:${color}"></div></div>
      <div class="score-val">${s}/10</div>
    </div>`;
  }).join('');

  // Combined
  combArea.innerHTML='<div style="border-top:1px solid var(--border);padding-top:10px;margin-top:4px;">'+
    allPlayers.map(p=>{
      const ai=S.gdAIScores[p.name]?.score||5;
      const aud=S.gdAudScores[p.name]||5;
      const comb=Math.round((ai*0.5+aud*0.5)*10)/10;
      const isYou=p.name===S.playerName;
      const verdict=comb>=7?'ADVANCE':comb>=5?'BORDERLINE':'ELIMINATED';
      const vc=comb>=7?'cv-advance':comb>=5?'cv-borderline':'cv-eliminated';
      const color=isYou?COLORS[3]:S.aiPlayers.find(a=>a.name===p.name)?.color||COLORS[0];
      return `<div class="combined-row">
        <div class="combined-label" style="color:${color}">${isYou?'You':p.name.split(' ')[0]}</div>
        <div class="combined-num">${comb}</div>
        <div class="combined-verdict ${vc}">${verdict}</div>
      </div>`;
    }).join('')+'</div>';
}

function toggleVote(name,btn){
  if(S.gdVotes[name]==='advance'){delete S.gdVotes[name];btn.classList.remove('selected-vote');}
  else{S.gdVotes[name]='advance';btn.classList.add('selected-vote');}
}
