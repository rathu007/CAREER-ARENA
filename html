// ── TOGGLE VOICE MODE ───────────────────────
function toggleVoiceMode(context) {
  if (!VOICE.supportsSpeech) {
    alert('Voice recognition is not supported in your browser.\nPlease use Chrome or Edge for the best experience.');
    return;
  }

  if (context === 'gd') {
    VOICE.gdMode = !VOICE.gdMode;
    const pill = document.getElementById('gd-voice-toggle');
    const bar  = document.getElementById('gd-voice-bar');
    const note = document.getElementById('gd-voice-notice');
    pill.classList.toggle('active', VOICE.gdMode);
    bar.style.display  = VOICE.gdMode ? 'flex' : 'none';
    note.classList.toggle('show', VOICE.gdMode);
    setVoiceStatus('gd', VOICE.gdMode ? 'Ready' : 'Off');

  } else if (context === 'iv') {
    VOICE.ivMode = !VOICE.ivMode;
    const pill = document.getElementById('iv-voice-toggle');
    const bar  = document.getElementById('iv-voice-bar');
    const note = document.getElementById('iv-voice-notice');
    pill.classList.toggle('active', VOICE.ivMode);
    bar.style.display  = VOICE.ivMode ? 'flex' : 'none';
    note.classList.toggle('show', VOICE.ivMode);
    setVoiceStatus('iv', VOICE.ivMode ? 'Ready' : 'Off');

    // When turning on IV voice, read the current question aloud
    if (VOICE.ivMode && S.ivQs.length) {
      const q = S.ivQs[S.currentIQ];
      if (q) speakText('Interview question: ' + q.q, 'iv');
    }
  }
}

// ── SET STATUS LABEL ────────────────────────
function setVoiceStatus(ctx, text, cls='') {
  const el = document.getElementById(`${ctx}-voice-status`);
  if (!el) return;
  el.textContent = text;
  el.className = 'voice-status' + (cls ? ' ' + cls : '');
}

// ── ANIMATE WAVEFORM ────────────────────────
function startWave(ctx) {
  const wave = document.getElementById(`${ctx}-wave`);
  if (!wave) return;
  wave.classList.add('active');
  if (ctx === 'iv') wave.classList.add('iv-wave');
  const bars = wave.querySelectorAll('.vw-bar');
  VOICE.waveInterval = setInterval(() => {
    bars.forEach(b => {
      b.style.height = (4 + Math.random() * 20) + 'px';
    });
  }, 100);
}
function stopWave(ctx) {
  const wave = document.getElementById(`${ctx}-wave`);
  if (!wave) return;
  wave.classList.remove('active','iv-wave');
  clearInterval(VOICE.waveInterval);
  wave.querySelectorAll('.vw-bar').forEach(b => b.style.height = '6px');
}

// ── BUILD RECOGNITION INSTANCE ──────────────
function buildRecognition(onResult, onEnd) {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  const rec = new SR();
  rec.continuous    = true;
  rec.interimResults = true;
  rec.lang          = 'en-IN';   // Indian English — best for placement context
  let finalText = '';

  rec.onresult = (e) => {
    let interim = '';
    for (let i = e.resultIndex; i < e.results.length; i++) {
      const t = e.results[i][0].transcript;
      if (e.results[i].isFinal) finalText += t + ' ';
      else interim = t;
    }
    onResult(finalText, interim);
  };
  rec.onerror = (e) => {
    console.warn('Speech recognition error:', e.error);
    if (e.error === 'not-allowed') {
      alert('Microphone access was denied. Please allow mic permissions and try again.');
    }
  };
  rec.onend = () => { onEnd(finalText); };
  return { rec, getFinal: () => finalText };
}

