const MISTRAL_KEY = 'Ca83dX5AzuAlzkxpmT8vtH0hBtL2liWd';
const MISTRAL_MODEL = 'mistral-large-latest';

async function callMistral(prompt, system = '') {
  const messages = [];
  if (system) messages.push({ role: 'system', content: system });
  messages.push({ role: 'user', content: prompt });

  const res = await fetch('https://api.mistral.ai/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${MISTRAL_KEY}`
    },
    body: JSON.stringify({
      model: MISTRAL_MODEL,
      max_tokens: 600,
      messages
    })
  });
  const data = await res.json();
  if (!res.ok) {
    console.error('Mistral API error:', data);
    return null;
  }
  return data.choices?.[0]?.message?.content || '';
}

async function callMistralJSON(prompt, system = '') {
  const raw = await callMistral(prompt, system);
  if (!raw) return null;
  try {
    return JSON.parse(raw.replace(/```json|```/g, '').trim());
  } catch(e) {
    // try to extract JSON object from response
    const match = raw.match(/\{[\s\S]*\}/);
    if (match) {
      try { return JSON.parse(match[0]); } catch(e2) {}
    }
    return null;
  }
}

// ════════════════════════════════════════════
//  CLAUDE API  (kept for GD speech generation)
// ════════════════════════════════════════════
async function callClaude(prompt, system=''){
  const body = { model:'claude-sonnet-4-20250514', max_tokens:1000, messages:[{role:'user',content:prompt}] };
  if(system) body.system=system;
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    const data = await res.json();
    return data.content.map(c=>c.text||'').join('');
  } catch(e) {
    // fallback to Mistral if Claude unavailable
    return await callMistral(prompt, system) || '';
  }
}
async function callClaudeJSON(prompt,system=''){
  const raw = await callClaude(prompt,system);
  try{ return JSON.parse(raw.replace(/```json|```/g,'').trim()); }catch(e){ return null; }
}

