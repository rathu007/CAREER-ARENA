<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Career Arena — Full Game</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,300&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#080810; --surface:#0f0f1a; --card:#13131f; --border:#1c1c2e;
  --accent:#f5c518; --accent2:#ff4d4d; --accent3:#00e5a0; --accent4:#4d9fff;
  --text:#e8e8f2; --muted:#525270; --muted2:#7070a0;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh;overflow-x:hidden;}
body::after{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");pointer-events:none;z-index:9999;}

.screen{display:none;min-height:100vh;}
.screen.active{display:flex;flex-direction:column;}

/* HEADER */
.arena-header{display:flex;justify-content:space-between;align-items:center;padding:16px 36px;border-bottom:1px solid var(--border);background:rgba(8,8,16,0.92);backdrop-filter:blur(14px);position:sticky;top:0;z-index:50;}
.logo{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:3px;color:var(--accent);}
.logo span{color:var(--text);}
.round-indicator{display:flex;gap:6px;align-items:center;}
.ri-step{font-family:'Space Mono',monospace;font-size:0.58rem;letter-spacing:1px;color:var(--muted);text-transform:uppercase;padding:5px 12px;border:1px solid var(--border);transition:all 0.3s;}
.ri-step.done{border-color:var(--accent3);color:var(--accent3);}
.ri-step.active{border-color:var(--accent);color:var(--accent);background:rgba(245,197,24,0.08);}
.ri-sep{color:var(--muted);font-size:0.8rem;}
.player-badge{font-family:'Space Mono',monospace;font-size:0.62rem;color:var(--muted);display:flex;align-items:center;gap:7px;}
.player-badge span{color:var(--accent);}
.badge-ava{font-size:1.1rem;line-height:1;}

/* LOBBY */
#screen-lobby{background:radial-gradient(ellipse 60% 50% at 20% 50%,rgba(245,197,24,0.07) 0%,transparent 60%),radial-gradient(ellipse 40% 60% at 80% 30%,rgba(77,159,255,0.05) 0%,transparent 60%),var(--bg);justify-content:center;align-items:center;}
.lobby-wrap{text-align:center;max-width:560px;padding:40px 20px;}
.lobby-tag{display:inline-flex;align-items:center;gap:8px;font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:3px;color:var(--accent);text-transform:uppercase;border:1px solid rgba(245,197,24,0.3);padding:6px 16px;margin-bottom:28px;}
.pulse{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:pulse 1.2s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.4;transform:scale(0.7)}}
.lobby-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(4rem,10vw,7.5rem);line-height:0.9;margin-bottom:20px;}
.lobby-title .t1{display:block;color:var(--text);}
.lobby-title .t2{display:block;-webkit-text-stroke:2px var(--accent);color:transparent;animation:hollowFlicker 3s ease-in-out infinite;}
@keyframes hollowFlicker{0%,100%{color:transparent}60%{color:var(--accent)}}
.lobby-sub{color:var(--muted2);font-size:0.95rem;line-height:1.7;margin-bottom:28px;}
.name-row{display:flex;gap:0;margin-bottom:16px;}
.name-input{flex:1;background:var(--card);border:1px solid var(--border);border-right:none;padding:16px 20px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:1rem;outline:none;transition:border-color 0.2s;}
.name-input:focus{border-color:var(--accent);}
.name-input::placeholder{color:var(--muted);}
.btn-enter{background:var(--accent);color:#080810;border:none;padding:16px 32px;font-family:'Space Mono',monospace;font-size:0.75rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;white-space:nowrap;clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);}
.btn-enter:hover{background:#fff;transform:translateY(-2px);box-shadow:0 8px 30px rgba(245,197,24,0.3);}
.lobby-info{display:flex;justify-content:center;gap:32px;margin-top:32px;}
.li-item{text-align:center;}
.li-num{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;color:var(--accent);}
.li-label{font-family:'Space Mono',monospace;font-size:0.55rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;}

/* AVATAR PICKER */
.ava-section{margin-bottom:22px;text-align:left;}
.ava-heading{font-family:'Space Mono',monospace;font-size:0.54rem;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-bottom:14px;display:flex;align-items:center;gap:10px;}
.ava-heading::after{content:'';flex:1;height:1px;background:var(--border);}
.ava-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:18px;}
.ava-btn{background:var(--card);border:2px solid var(--border);border-radius:14px;padding:18px 6px 12px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:8px;transition:transform 0.18s,border-color 0.18s,box-shadow 0.18s,background 0.18s;position:relative;}
.ava-btn:hover{border-color:var(--muted2);transform:translateY(-5px);box-shadow:0 10px 28px rgba(0,0,0,0.4);}
.ava-btn.selected{border-color:var(--accent);background:rgba(245,197,24,0.08);transform:translateY(-5px);box-shadow:0 10px 32px rgba(245,197,24,0.22);}
.ava-btn.selected::after{content:'✓';position:absolute;top:6px;right:8px;font-family:'Space Mono',monospace;font-size:0.48rem;color:var(--accent);}
.ava-emoji{font-size:2.3rem;line-height:1;pointer-events:none;}
.ava-label{font-family:'Space Mono',monospace;font-size:0.46rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);transition:color 0.18s;pointer-events:none;}
.ava-btn.selected .ava-label{color:var(--accent);}
.ava-preview{display:flex;align-items:center;gap:15px;padding:13px 18px;background:var(--card);border:1px solid var(--border);margin-bottom:16px;min-height:58px;transition:border-color 0.25s,background 0.25s;}
.ava-preview.lit{border-color:rgba(245,197,24,0.4);background:rgba(245,197,24,0.04);}
.avp-emoji{font-size:2rem;flex-shrink:0;line-height:1;}
.avp-info{text-align:left;}
.avp-name{font-size:0.92rem;font-weight:500;color:var(--text);margin-bottom:2px;}
.avp-hint{font-family:'Space Mono',monospace;font-size:0.48rem;color:var(--muted);letter-spacing:1px;text-transform:uppercase;}

/* LOADING */
#screen-loading{justify-content:center;align-items:center;background:var(--bg);}
.loading-inner{text-align:center;}
.loading-ring{width:72px;height:72px;border-radius:50%;border:3px solid var(--border);border-top-color:var(--accent);animation:spin 0.8s linear infinite;margin:0 auto 20px;}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{font-family:'Space Mono',monospace;font-size:0.75rem;letter-spacing:3px;color:var(--muted);text-transform:uppercase;}
.loading-sub{color:var(--accent);margin-top:8px;font-size:0.85rem;}

/* QUIZ SCOREBOARD */
#screen-quiz{background:var(--bg);}
.quiz-layout{flex:1;display:grid;grid-template-columns:1fr 260px;gap:0;max-width:1160px;margin:0 auto;width:100%;}
.quiz-main{padding:36px 32px;display:flex;flex-direction:column;}
.quiz-sidebar{border-left:1px solid var(--border);background:var(--surface);padding:24px 18px;display:flex;flex-direction:column;gap:0;}
.sb-title{font-family:'Space Mono',monospace;font-size:0.54rem;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;}
.sb-qcount{font-size:0.5rem;color:var(--muted2);}
.sb-players{display:flex;flex-direction:column;gap:8px;}
.sb-row{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:11px 13px;transition:border-color 0.35s,background 0.35s;position:relative;overflow:hidden;}
.sb-row.is-you{border-color:rgba(245,197,24,0.3);}
.sb-row.is-leader{border-color:var(--accent);background:rgba(245,197,24,0.06);}
.sb-row.climbed{animation:sbClimb 0.5s ease;}
@keyframes sbClimb{0%{transform:translateY(8px);opacity:0.5}100%{transform:translateY(0);opacity:1}}
.sb-row-top{display:flex;align-items:center;gap:8px;margin-bottom:7px;}
.sb-rank{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;line-height:1;width:18px;text-align:center;flex-shrink:0;color:var(--muted);}
.sb-rank.r1{color:var(--accent);}
.sb-rank.r2{color:var(--muted2);}
.sb-rank.r3{color:#cd7f32;}
.sb-avatar{font-size:1.1rem;line-height:1;flex-shrink:0;}
.sb-info{flex:1;min-width:0;}
.sb-name{font-size:0.78rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--text);}
.sb-name.you-tag::after{content:' (You)';font-size:0.65rem;color:var(--accent);font-weight:400;}
.sb-pts{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;line-height:1;color:var(--text);flex-shrink:0;}
.sb-pts.leader-pts{color:var(--accent);}
.sb-bar-wrap{height:3px;background:var(--border);border-radius:2px;overflow:hidden;}
.sb-bar{height:100%;border-radius:2px;transition:width 0.55s cubic-bezier(0.34,1.56,0.64,1);width:0%;}
.sb-crown{position:absolute;top:6px;right:10px;font-size:0.9rem;animation:crownPop 0.4s ease;}
@keyframes crownPop{0%{transform:scale(0) rotate(-20deg);opacity:0}70%{transform:scale(1.3) rotate(5deg)}100%{transform:scale(1) rotate(0);opacity:1}}
.sb-delta{font-family:'Space Mono',monospace;font-size:0.46rem;padding:1px 5px;border-radius:3px;margin-left:4px;vertical-align:middle;}
.sb-delta.up{background:rgba(0,229,160,0.15);color:var(--accent3);}
.sb-delta.same{background:rgba(112,112,160,0.1);color:var(--muted);}
.sb-divider{height:1px;background:var(--border);margin:14px 0;}
.sb-stat-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.sb-stat-lbl{font-family:'Space Mono',monospace;font-size:0.5rem;color:var(--muted);letter-spacing:1px;text-transform:uppercase;}
.sb-stat-val{font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--text);}
.sb-stat-val.hi{color:var(--accent3);}
.sb-stat-val.lo{color:var(--accent2);}
.quiz-meta{display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;}
.q-progress-wrap{flex:1;margin-right:28px;}
.q-progress-label{font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;display:flex;justify-content:space-between;}
.q-progress-bar{height:4px;background:var(--border);border-radius:2px;overflow:hidden;}
.q-progress-fill{height:100%;background:var(--accent);border-radius:2px;transition:width 0.4s ease;}
.q-timer{width:68px;height:68px;position:relative;flex-shrink:0;}
.q-timer svg{transform:rotate(-90deg);}
.q-timer-text{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--accent);}
.q-timer.urgent .q-timer-text{color:var(--accent2);animation:timerShake 0.3s infinite;}
@keyframes timerShake{0%,100%{transform:translateX(0)}50%{transform:translateX(2px)}}
.q-card{background:var(--card);border:1px solid var(--border);padding:36px;margin-bottom:20px;position:relative;overflow:hidden;animation:slideIn 0.35s ease;}
@keyframes slideIn{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
.q-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--accent);}
.q-number{font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--accent);letter-spacing:3px;text-transform:uppercase;margin-bottom:14px;}
.q-text{font-size:1.1rem;line-height:1.65;font-weight:500;margin-bottom:28px;}
.q-options{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.q-option{background:var(--surface);border:1px solid var(--border);padding:14px 18px;cursor:pointer;font-size:0.88rem;line-height:1.4;transition:all 0.2s;text-align:left;position:relative;overflow:hidden;color:var(--text);}
.q-option:hover{border-color:var(--accent);background:rgba(245,197,24,0.05);transform:translateX(4px);}
.q-option.selected{border-color:var(--accent);background:rgba(245,197,24,0.12);color:var(--accent);}
.q-option.correct{border-color:var(--accent3);background:rgba(0,229,160,0.12);color:var(--accent3);}
.q-option.wrong{border-color:var(--accent2);background:rgba(255,77,77,0.1);color:var(--accent2);}
.q-option:disabled{cursor:default;}
.q-option-letter{font-family:'Space Mono',monospace;font-size:0.65rem;font-weight:700;margin-right:10px;opacity:0.6;}
.q-feedback{min-height:44px;padding:10px 16px;font-size:0.86rem;line-height:1.5;border-left:3px solid transparent;margin-bottom:14px;transition:all 0.3s;}
.q-feedback.correct-fb{border-color:var(--accent3);background:rgba(0,229,160,0.05);color:var(--accent3);}
.q-feedback.wrong-fb{border-color:var(--accent2);background:rgba(255,77,77,0.05);color:var(--muted2);}
.q-footer{display:flex;justify-content:space-between;align-items:center;}
.q-score-mini{font-family:'Space Mono',monospace;font-size:0.65rem;color:var(--muted);}
.q-score-mini span{color:var(--accent3);}
.btn-next{background:var(--accent);color:#080810;border:none;padding:13px 26px;font-family:'Space Mono',monospace;font-size:0.68rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);}
.btn-next:hover{background:#fff;}
.btn-next:disabled{opacity:0.4;cursor:default;}

/* QUIZ RESULT */
#screen-quiz-result{justify-content:center;align-items:center;background:radial-gradient(ellipse 60% 60% at 50% 50%,rgba(0,229,160,0.07) 0%,transparent 70%),var(--bg);}
.result-card{background:var(--card);border:1px solid var(--border);padding:48px 44px;max-width:500px;width:90%;text-align:center;position:relative;overflow:hidden;}
.result-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;}
.result-card.pass::before{background:var(--accent3);}
.result-card.fail::before{background:var(--accent2);}
.result-icon{font-size:3.2rem;margin-bottom:18px;display:block;}
.result-title{font-family:'Bebas Neue',sans-serif;font-size:3.2rem;letter-spacing:2px;margin-bottom:8px;}
.result-card.pass .result-title{color:var(--accent3);}
.result-card.fail .result-title{color:var(--accent2);}
.result-score{font-family:'Bebas Neue',sans-serif;font-size:4.5rem;color:var(--accent);line-height:1;margin:14px 0;}
.result-score sub{font-size:1.8rem;color:var(--muted);}
.result-sub{color:var(--muted2);font-size:0.88rem;line-height:1.6;margin-bottom:24px;}
.result-btn{background:var(--accent);color:#080810;border:none;padding:15px 32px;font-family:'Space Mono',monospace;font-size:0.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;width:100%;margin-bottom:10px;}
.result-btn:hover{background:#fff;}
.result-btn.ghost{background:transparent;color:var(--muted2);border:1px solid var(--border);margin-bottom:0;}
.result-btn.ghost:hover{border-color:var(--muted2);color:var(--text);}

/* JUDGE */
#screen-judge{justify-content:center;align-items:center;background:radial-gradient(ellipse 60% 50% at 50% 50%,rgba(255,77,77,0.06) 0%,transparent 70%),var(--bg);}
.judge-wrap{max-width:500px;text-align:center;padding:40px 20px;}
.judge-icon{font-size:3.5rem;margin-bottom:20px;display:block;animation:float 3s ease-in-out infinite;}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.judge-title{font-family:'Bebas Neue',sans-serif;font-size:3rem;color:var(--accent2);margin-bottom:10px;}
.judge-sub{color:var(--muted2);font-size:0.9rem;line-height:1.7;margin-bottom:28px;}
.judge-btn{background:var(--accent2);color:#fff;border:none;padding:15px 32px;width:100%;font-family:'Space Mono',monospace;font-size:0.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;}
.judge-btn:hover{background:#ff6b6b;}

/* GD */
#screen-gd{background:var(--bg);}
.gd-body{flex:1;display:grid;grid-template-columns:1fr 340px;}
.gd-main{padding:32px 36px;border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;}
.gd-topic-reveal{background:var(--card);border:1px solid var(--border);padding:24px 28px;margin-bottom:24px;position:relative;overflow:hidden;}
.gd-topic-reveal::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--accent3);}
.gd-topic-label{font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--accent3);letter-spacing:3px;text-transform:uppercase;margin-bottom:8px;}
.gd-topic-text{font-size:1.15rem;font-weight:600;line-height:1.4;}
.gd-phase{display:flex;align-items:center;gap:14px;margin-bottom:20px;}
.phase-badge{font-family:'Space Mono',monospace;font-size:0.58rem;letter-spacing:2px;text-transform:uppercase;padding:5px 12px;border:1px solid;}
.phase-badge.prep{border-color:var(--accent4);color:var(--accent4);background:rgba(77,159,255,0.1);}
.phase-badge.speak{border-color:var(--accent3);color:var(--accent3);background:rgba(0,229,160,0.1);}
.phase-badge.voting{border-color:var(--accent);color:var(--accent);background:rgba(245,197,24,0.1);}
.phase-desc{color:var(--muted2);font-size:0.83rem;}
.gd-timer-big{text-align:center;margin-bottom:20px;}
.gd-timer-num{font-family:'Bebas Neue',sans-serif;font-size:5.5rem;line-height:1;color:var(--accent);transition:color 0.3s;}
.gd-timer-num.low{color:var(--accent2);animation:timerShake 0.4s infinite;}
.gd-timer-label{font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--muted);letter-spacing:3px;text-transform:uppercase;}
.section-lbl{font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;}
.gd-notes{width:100%;background:var(--surface);border:1px solid var(--border);padding:14px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.9rem;line-height:1.6;resize:none;outline:none;min-height:110px;transition:border-color 0.2s;}
.gd-notes:focus{border-color:var(--accent4);}
.gd-notes::placeholder{color:var(--muted);}
.gd-notes:disabled{opacity:0.5;cursor:default;}
.gd-action-row{display:flex;justify-content:flex-end;margin-top:14px;gap:10px;}
.btn-speak{background:var(--accent3);color:#080810;border:none;padding:13px 28px;font-family:'Space Mono',monospace;font-size:0.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);}
.btn-speak:hover{background:#00ffb3;}
.btn-speak:disabled{opacity:0.4;cursor:default;}

/* DUAL SCORE PANEL */
.dual-score-panel{background:var(--card);border:1px solid var(--border);padding:20px;margin-top:16px;}
.dsp-title{font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid var(--border);}
.dsp-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.dsp-half{display:flex;flex-direction:column;gap:8px;}
.dsp-half-title{font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:1px;text-transform:uppercase;padding:4px 8px;border:1px solid;text-align:center;margin-bottom:4px;}
.dsp-half-title.ai-title{border-color:var(--accent4);color:var(--accent4);}
.dsp-half-title.aud-title{border-color:var(--accent3);color:var(--accent3);}
.score-row{display:flex;align-items:center;gap:8px;}
.score-name{font-size:0.78rem;min-width:62px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.score-bar-wrap{flex:1;height:5px;background:var(--border);border-radius:3px;overflow:hidden;}
.score-fill{height:100%;border-radius:3px;transition:width 0.8s ease;}
.score-val{font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--muted);min-width:28px;text-align:right;}
.combined-row{display:flex;align-items:center;gap:8px;padding:8px 0;border-top:1px solid var(--border);margin-top:4px;}
.combined-label{font-family:'Space Mono',monospace;font-size:0.55rem;color:var(--muted);letter-spacing:1px;text-transform:uppercase;min-width:62px;}
.combined-num{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;color:var(--accent);}
.combined-verdict{font-family:'Space Mono',monospace;font-size:0.6rem;padding:2px 8px;border:1px solid;}
.cv-advance{border-color:var(--accent3);color:var(--accent3);}
.cv-borderline{border-color:var(--accent);color:var(--accent);}
.cv-eliminated{border-color:var(--accent2);color:var(--accent2);}

/* GD SIDEBAR */
.gd-sidebar{background:var(--surface);padding:24px 20px;overflow-y:auto;display:flex;flex-direction:column;gap:20px;}
.sidebar-section{}
.sidebar-title{font-family:'Space Mono',monospace;font-size:0.56rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;padding-bottom:7px;border-bottom:1px solid var(--border);}
.player-list{display:flex;flex-direction:column;gap:7px;}
.player-row{display:flex;align-items:center;gap:9px;padding:9px 11px;background:var(--card);border:1px solid var(--border);transition:all 0.2s;}
.player-row.speaking{border-color:var(--accent3);background:rgba(0,229,160,0.05);}
.player-row.you{border-color:var(--accent);}
.p-ava{width:28px;height:28px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:'Space Mono',monospace;font-size:0.62rem;font-weight:700;}
.p-name{font-size:0.8rem;flex:1;}
.p-status{font-family:'Space Mono',monospace;font-size:0.52rem;letter-spacing:1px;text-transform:uppercase;}
.p-status.waiting{color:var(--muted);}
.p-status.speaking{color:var(--accent3);}
.p-status.done{color:var(--muted2);}
.ai-speech-block{background:var(--card);border:1px solid var(--border);padding:14px;margin-bottom:8px;position:relative;}
.ai-speech-meta{display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;}
.ai-speech-name{font-size:0.78rem;font-weight:600;}
.ai-speech-time{font-family:'Space Mono',monospace;font-size:0.52rem;color:var(--muted);}
.ai-speech-text{font-size:0.8rem;color:var(--muted2);line-height:1.6;}

/* GD VOTE */
.vote-card-ui{background:var(--card);border:1px solid var(--border);padding:14px;margin-bottom:9px;}
.vote-card-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.vote-cand-name{font-size:0.88rem;font-weight:600;}
.vote-cand-speech{font-size:0.78rem;color:var(--muted2);margin-bottom:10px;line-height:1.5;}
.vote-actions{display:flex;gap:7px;}
.vote-btn{flex:1;padding:9px 0;font-family:'Space Mono',monospace;font-size:0.58rem;letter-spacing:1px;text-transform:uppercase;border:1px solid var(--border);background:transparent;color:var(--muted2);cursor:pointer;transition:all 0.2s;}
.vote-btn:hover{border-color:var(--accent3);color:var(--accent3);background:rgba(0,229,160,0.08);}
.vote-btn.selected-vote{border-color:var(--accent3);color:var(--accent3);background:rgba(0,229,160,0.12);}
.vote-submit-btn{width:100%;padding:13px;margin-top:10px;background:var(--accent);color:#080810;border:none;font-family:'Space Mono',monospace;font-size:0.68rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;}
.vote-submit-btn:hover{background:#fff;}
.vote-submit-btn:disabled{opacity:0.4;cursor:default;}

/* INTERVIEW */
#screen-interview{background:var(--bg);}
.interview-body{flex:1;display:grid;grid-template-columns:1fr 340px;}
.interview-main{padding:32px 36px;border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;}
.interview-q-card{background:var(--card);border:1px solid var(--border);padding:28px;margin-bottom:20px;position:relative;overflow:hidden;animation:slideIn 0.35s ease;}
.interview-q-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--accent2);}
.iq-meta{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;}
.iq-label{font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--accent2);letter-spacing:2px;text-transform:uppercase;}
.iq-category{font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--muted);padding:3px 10px;border:1px solid var(--border);letter-spacing:1px;text-transform:uppercase;}
.iq-text{font-size:1.08rem;line-height:1.65;font-weight:500;}
.answer-textarea{width:100%;min-height:150px;background:var(--surface);border:1px solid var(--border);padding:14px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.92rem;line-height:1.65;resize:vertical;outline:none;transition:border-color 0.2s;margin-bottom:14px;}
.answer-textarea:focus{border-color:var(--accent2);}
.answer-textarea::placeholder{color:var(--muted);}
.interview-footer{display:flex;justify-content:space-between;align-items:center;}
.q-counter{font-family:'Space Mono',monospace;font-size:0.62rem;color:var(--muted);}
.q-counter span{color:var(--accent);}
.btn-submit-iv{background:var(--accent2);color:#fff;border:none;padding:13px 28px;font-family:'Space Mono',monospace;font-size:0.68rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);}
.btn-submit-iv:hover{background:#ff6b6b;}
.btn-submit-iv:disabled{opacity:0.4;cursor:default;}

/* AI REVIEW */
.ai-review-block{background:var(--surface);border:1px solid var(--border);padding:18px;margin-bottom:16px;animation:slideIn 0.4s ease;}
.air-header{display:flex;align-items:center;gap:10px;margin-bottom:10px;flex-wrap:wrap;}
.air-source{font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--muted);letter-spacing:1px;text-transform:uppercase;}
.air-verdict{font-family:'Space Mono',monospace;font-size:0.62rem;font-weight:700;padding:3px 10px;letter-spacing:1px;}
.air-verdict.hire{background:rgba(0,229,160,0.2);color:var(--accent3);}
.air-verdict.maybe{background:rgba(245,197,24,0.2);color:var(--accent);}
.air-verdict.pass{background:rgba(255,77,77,0.15);color:var(--accent2);}
.air-score{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--accent);}
.air-text{font-size:0.83rem;color:var(--muted2);line-height:1.65;}

/* INTERVIEW SIDEBAR */
.interview-sidebar{background:var(--surface);padding:24px 20px;overflow-y:auto;display:flex;flex-direction:column;gap:20px;}
.audience-item{display:flex;align-items:center;gap:9px;padding:9px 11px;background:var(--card);border:1px solid var(--border);margin-bottom:7px;}
.av-ava{width:26px;height:26px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:'Space Mono',monospace;font-size:0.58rem;font-weight:700;}
.av-name{font-size:0.78rem;flex:1;}
.av-verdict{font-family:'Space Mono',monospace;font-size:0.52rem;letter-spacing:1px;text-transform:uppercase;padding:2px 7px;border:1px solid;}
.av-verdict.hire{border-color:var(--accent3);color:var(--accent3);}
.av-verdict.maybe{border-color:var(--accent);color:var(--accent);}
.av-verdict.pass{border-color:var(--accent2);color:var(--accent2);}
.av-verdict.thinking{border-color:var(--border);color:var(--muted);}

/* INTERVIEW DUAL SCORE */
.iv-dual-panel{background:var(--card);border:1px solid var(--border);padding:16px;}
.iv-score-tabs{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;}
.iv-tab{padding:8px;text-align:center;background:var(--surface);border:1px solid var(--border);}
.iv-tab-label{font-family:'Space Mono',monospace;font-size:0.52rem;color:var(--muted);letter-spacing:1px;text-transform:uppercase;}
.iv-tab-score{font-family:'Bebas Neue',sans-serif;font-size:2rem;line-height:1;}
.iv-tab.ai-tab .iv-tab-score{color:var(--accent4);}
.iv-tab.aud-tab .iv-tab-score{color:var(--accent3);}
.iv-combined-score{text-align:center;padding:10px 0;border-top:1px solid var(--border);}
.iv-comb-label{font-family:'Space Mono',monospace;font-size:0.52rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;}
.iv-comb-num{font-family:'Bebas Neue',sans-serif;font-size:3rem;color:var(--accent);line-height:1;}
.iv-comb-verdict{display:inline-block;font-family:'Space Mono',monospace;font-size:0.6rem;padding:3px 10px;border:1px solid;margin-top:4px;letter-spacing:1px;text-transform:uppercase;}

/* FINAL */
#screen-final{justify-content:center;align-items:center;background:radial-gradient(ellipse 70% 60% at 50% 50%,rgba(245,197,24,0.1) 0%,transparent 70%),var(--bg);}
.final-wrap{max-width:640px;width:92%;text-align:center;padding:40px 20px;}
.trophy{font-size:4.5rem;margin-bottom:14px;display:block;animation:trophyBounce 0.8s ease;}
@keyframes trophyBounce{0%{transform:scale(0)rotate(-20deg)}70%{transform:scale(1.15)rotate(5deg)}100%{transform:scale(1)rotate(0)}}
.final-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.8rem,7vw,5.5rem);color:var(--accent);margin-bottom:6px;}
.final-name{font-family:'Bebas Neue',sans-serif;font-size:clamp(1.8rem,4vw,3rem);color:var(--text);margin-bottom:28px;}
.final-podium{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:28px;}
.podium-card{background:var(--card);border:1px solid var(--border);padding:20px 10px;text-align:center;position:relative;overflow:hidden;}
.podium-card.gold{border-color:var(--accent);}
.podium-card.silver{border-color:#aaa;}
.podium-card.bronze{border-color:#cd7f32;}
.podium-rank{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;margin-bottom:4px;}
.podium-card.gold .podium-rank{color:var(--accent);}
.podium-card.silver .podium-rank{color:#aaa;}
.podium-card.bronze .podium-rank{color:#cd7f32;}
.podium-pname{font-size:0.88rem;font-weight:600;margin-bottom:4px;}
.podium-breakdown{font-family:'Space Mono',monospace;font-size:0.52rem;color:var(--muted);line-height:1.6;}
.play-again-btn{background:var(--accent);color:#080810;border:none;padding:16px 44px;font-family:'Space Mono',monospace;font-size:0.78rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;clip-path:polygon(12px 0%,100% 0%,calc(100% - 12px) 100%,0% 100%);}
.play-again-btn:hover{background:#fff;transform:translateY(-3px);box-shadow:0 12px 40px rgba(245,197,24,0.3);}

/* UTILS */
.ai-thinking{display:flex;align-items:center;gap:8px;font-family:'Space Mono',monospace;font-size:0.68rem;color:var(--muted);padding:10px 0;}
.ai-dots span{display:inline-block;width:5px;height:5px;border-radius:50%;background:var(--accent);margin:0 2px;animation:dotBounce 1.2s infinite;}
.ai-dots span:nth-child(2){animation-delay:0.2s}
.ai-dots span:nth-child(3){animation-delay:0.4s}
@keyframes dotBounce{0%,80%,100%{transform:scale(0.6);opacity:0.5}40%{transform:scale(1);opacity:1}}
.confetti-container{position:fixed;inset:0;pointer-events:none;z-index:100;overflow:hidden;}
.confetti-piece{position:absolute;width:8px;height:8px;animation:confettiFall linear forwards;}
@keyframes confettiFall{0%{transform:translateY(-20px)rotate(0deg);opacity:1}100%{transform:translateY(110vh)rotate(720deg);opacity:0}}

/* ══════════════════════════════════════
   VOICE CHAT FEATURE
══════════════════════════════════════ */

/* Voice bar — floats at bottom of GD + Interview screens */
.voice-bar{display:flex;align-items:center;gap:12px;padding:14px 20px;background:var(--card);border:1px solid var(--border);border-top:2px solid var(--accent3);margin-top:16px;position:relative;}
.voice-bar.iv-voice{border-top-color:var(--accent2);}
.voice-bar-label{font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);white-space:nowrap;}

/* Mic button */
.mic-btn{width:44px;height:44px;border-radius:50%;border:2px solid var(--accent3);background:transparent;color:var(--accent3);font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;flex-shrink:0;position:relative;}
.mic-btn:hover{background:rgba(0,229,160,0.1);}
.mic-btn.recording{background:rgba(255,77,77,0.15);border-color:var(--accent2);color:var(--accent2);animation:micPulse 1s infinite;}
.mic-btn.iv-mic{border-color:var(--accent2);color:var(--accent2);}
.mic-btn.iv-mic.recording{border-color:var(--accent2);background:rgba(255,77,77,0.2);}
@keyframes micPulse{0%,100%{box-shadow:0 0 0 0 rgba(255,77,77,0.4)}50%{box-shadow:0 0 0 10px rgba(255,77,77,0)}}

/* Waveform visualizer */
.voice-wave{display:flex;align-items:center;gap:3px;height:28px;flex:1;}
.vw-bar{width:3px;border-radius:2px;background:var(--border);transition:height 0.1s ease;}
.voice-wave.active .vw-bar{background:var(--accent3);}
.voice-wave.iv-wave.active .vw-bar{background:var(--accent2);}

/* Voice status text */
.voice-status{font-family:'Space Mono',monospace;font-size:0.6rem;color:var(--muted);min-width:110px;letter-spacing:1px;}
.voice-status.vs-recording{color:var(--accent2);}
.voice-status.vs-processing{color:var(--accent);}
.voice-status.vs-speaking{color:var(--accent3);}

/* Voice transcript bubble — shows live recognised speech */
.voice-transcript{flex:1;font-size:0.82rem;color:var(--muted2);line-height:1.5;min-height:20px;font-style:italic;}
.voice-transcript.vt-live{color:var(--text);}

/* Use-voice toggle pill */
.voice-toggle-row{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.voice-toggle-pill{display:flex;align-items:center;gap:8px;background:var(--surface);border:1px solid var(--border);padding:7px 14px;cursor:pointer;transition:all 0.2s;font-family:'Space Mono',monospace;font-size:0.58rem;letter-spacing:1px;text-transform:uppercase;color:var(--muted);}
.voice-toggle-pill.active{border-color:var(--accent3);color:var(--accent3);background:rgba(0,229,160,0.06);}
.voice-toggle-pill.iv-pill.active{border-color:var(--accent2);color:var(--accent2);background:rgba(255,77,77,0.06);}
.vtp-dot{width:7px;height:7px;border-radius:50%;background:var(--muted);flex-shrink:0;transition:background 0.2s;}
.voice-toggle-pill.active .vtp-dot{background:var(--accent3);}
.voice-toggle-pill.iv-pill.active .vtp-dot{background:var(--accent2);}

/* AI voice indicator — plays when AI speaks */
.ai-speaking-chip{display:none;align-items:center;gap:8px;font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--accent4);letter-spacing:1px;text-transform:uppercase;padding:5px 12px;border:1px solid rgba(77,159,255,0.3);background:rgba(77,159,255,0.06);}
.ai-speaking-chip.visible{display:flex;}
.ai-wave{display:flex;gap:2px;align-items:center;}
.ai-wave span{display:inline-block;width:2px;background:var(--accent4);border-radius:1px;animation:aiWave 0.8s infinite ease-in-out;}
.ai-wave span:nth-child(1){height:6px;animation-delay:0s;}
.ai-wave span:nth-child(2){height:12px;animation-delay:0.1s;}
.ai-wave span:nth-child(3){height:8px;animation-delay:0.2s;}
.ai-wave span:nth-child(4){height:14px;animation-delay:0.15s;}
.ai-wave span:nth-child(5){height:6px;animation-delay:0.05s;}
@keyframes aiWave{0%,100%{transform:scaleY(0.4)}50%{transform:scaleY(1)}}

/* Voice mode notice banner */
.voice-mode-notice{background:rgba(0,229,160,0.06);border:1px solid rgba(0,229,160,0.2);padding:10px 16px;font-size:0.8rem;color:var(--accent3);line-height:1.55;margin-bottom:14px;display:none;}
.voice-mode-notice.show{display:block;}
.voice-mode-notice.iv-notice{background:rgba(255,77,77,0.06);border-color:rgba(255,77,77,0.2);color:var(--accent2);}

/* ── GUIDE BUTTON ── */
.guide-fab{position:fixed;bottom:28px;right:28px;z-index:900;background:var(--card);border:1px solid var(--accent);color:var(--accent);font-family:'Space Mono',monospace;font-size:0.6rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:11px 18px;cursor:pointer;display:flex;align-items:center;gap:8px;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);transition:all 0.25s;box-shadow:0 0 24px rgba(245,197,24,0.12);}
.guide-fab:hover{background:var(--accent);color:#080810;box-shadow:0 0 36px rgba(245,197,24,0.35);}
.guide-fab .gf-icon{font-size:1rem;}

/* ── GUIDE OVERLAY ── */
.guide-overlay{position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity 0.35s ease;}
.guide-overlay.open{opacity:1;pointer-events:all;}
.guide-backdrop{position:absolute;inset:0;background:rgba(4,4,10,0.92);backdrop-filter:blur(18px);}
.guide-modal{position:relative;z-index:1;width:100%;max-width:860px;max-height:90vh;display:flex;flex-direction:column;background:var(--card);border:1px solid var(--border);transform:translateY(30px) scale(0.97);transition:transform 0.35s cubic-bezier(0.34,1.4,0.64,1);}
.guide-overlay.open .guide-modal{transform:translateY(0) scale(1);}

/* header */
.guide-header{display:flex;align-items:center;justify-content:space-between;padding:22px 28px;border-bottom:1px solid var(--border);flex-shrink:0;}
.guide-header-left{display:flex;flex-direction:column;gap:4px;}
.guide-eyebrow{font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:3px;text-transform:uppercase;color:var(--accent);display:flex;align-items:center;gap:8px;}
.guide-eyebrow::before{content:'';display:inline-block;width:20px;height:1px;background:var(--accent);}
.guide-title{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:3px;color:var(--text);}
.guide-close{width:36px;height:36px;border:1px solid var(--border);background:transparent;color:var(--muted);font-size:1.1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;flex-shrink:0;}
.guide-close:hover{border-color:var(--accent2);color:var(--accent2);}

/* step nav tabs */
.guide-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);flex-shrink:0;overflow-x:auto;}
.guide-tab{flex:1;min-width:80px;padding:12px 8px;font-family:'Space Mono',monospace;font-size:0.52rem;letter-spacing:1px;text-transform:uppercase;color:var(--muted);border:none;background:transparent;cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;display:flex;flex-direction:column;align-items:center;gap:5px;white-space:nowrap;}
.guide-tab .gt-icon{font-size:1.1rem;}
.guide-tab:hover{color:var(--text);background:rgba(255,255,255,0.02);}
.guide-tab.active{color:var(--accent);border-bottom-color:var(--accent);background:rgba(245,197,24,0.04);}
.guide-tab.done-tab{color:var(--accent3);}
.guide-tab.done-tab.active{color:var(--accent3);border-bottom-color:var(--accent3);}

/* content */
.guide-content{flex:1;overflow-y:auto;padding:0;}
.guide-panel{display:none;animation:gpFadeIn 0.3s ease;}
.guide-panel.active{display:block;}
@keyframes gpFadeIn{from{opacity:0;transform:translateX(12px)}to{opacity:1;transform:translateX(0)}}

/* hero panel (overview) */
.gp-hero{padding:32px 28px;background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(245,197,24,0.06) 0%,transparent 70%);}
.gp-hero-title{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:2px;color:var(--accent);margin-bottom:8px;}
.gp-hero-sub{color:var(--muted2);font-size:0.9rem;line-height:1.7;max-width:640px;margin-bottom:28px;}
.flow-track{display:flex;align-items:center;gap:0;flex-wrap:wrap;gap:0;}
.flow-node{display:flex;flex-direction:column;align-items:center;text-align:center;padding:16px 20px;background:var(--surface);border:1px solid var(--border);min-width:130px;flex:1;position:relative;}
.flow-node.fn-active{border-color:var(--accent);background:rgba(245,197,24,0.05);}
.flow-node .fn-badge{font-family:'Space Mono',monospace;font-size:0.48rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;}
.flow-node .fn-icon{font-size:1.6rem;margin-bottom:6px;}
.flow-node .fn-name{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:1px;color:var(--text);}
.flow-node .fn-tag{font-family:'Space Mono',monospace;font-size:0.44rem;color:var(--muted);margin-top:4px;letter-spacing:1px;}
.flow-arrow{color:var(--muted);font-size:1.1rem;padding:0 4px;flex-shrink:0;}
.scoring-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:24px;}
.sg-card{background:var(--surface);border:1px solid var(--border);padding:16px 18px;}
.sg-card-title{font-family:'Space Mono',monospace;font-size:0.58rem;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:8px;}
.sg-card-body{font-size:0.82rem;color:var(--muted2);line-height:1.65;}
.sg-card-body strong{color:var(--text);}

/* detail panels */
.gp-detail{padding:28px;}
.gp-section-label{font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:3px;text-transform:uppercase;color:var(--accent);margin-bottom:18px;display:flex;align-items:center;gap:10px;}
.gp-section-label::after{content:'';flex:1;height:1px;background:var(--border);}
.step-cards{display:flex;flex-direction:column;gap:12px;}
.step-card{display:flex;gap:18px;background:var(--surface);border:1px solid var(--border);padding:18px 20px;position:relative;overflow:hidden;transition:border-color 0.2s;}
.step-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;}
.step-card.sc-quiz::before{background:var(--accent);}
.step-card.sc-gd::before{background:var(--accent3);}
.step-card.sc-iv::before{background:var(--accent2);}
.step-card.sc-final::before{background:var(--accent4);}
.step-card.sc-info::before{background:var(--muted);}
.sc-num{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;line-height:1;flex-shrink:0;width:36px;}
.step-card.sc-quiz .sc-num{color:var(--accent);}
.step-card.sc-gd .sc-num{color:var(--accent3);}
.step-card.sc-iv .sc-num{color:var(--accent2);}
.step-card.sc-final .sc-num{color:var(--accent4);}
.sc-body{}
.sc-head{font-weight:600;font-size:0.92rem;margin-bottom:5px;}
.sc-desc{font-size:0.82rem;color:var(--muted2);line-height:1.65;}
.sc-tags{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px;}
.sc-tag{font-family:'Space Mono',monospace;font-size:0.5rem;letter-spacing:1px;text-transform:uppercase;padding:3px 9px;border:1px solid var(--border);color:var(--muted);}
.sc-tag.t-time{border-color:var(--accent4);color:var(--accent4);}
.sc-tag.t-score{border-color:var(--accent3);color:var(--accent3);}
.sc-tag.t-warn{border-color:var(--accent);color:var(--accent);}

/* tips panel */
.tips-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.tip-card{background:var(--surface);border:1px solid var(--border);padding:18px 20px;}
.tip-round{font-family:'Space Mono',monospace;font-size:0.52rem;letter-spacing:2px;text-transform:uppercase;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border);}
.tip-round.tr-q{color:var(--accent);}
.tip-round.tr-gd{color:var(--accent3);}
.tip-round.tr-iv{color:var(--accent2);}
.tip-round.tr-gen{color:var(--accent4);}
.tip-list{list-style:none;display:flex;flex-direction:column;gap:8px;}
.tip-list li{font-size:0.81rem;color:var(--muted2);line-height:1.55;display:flex;gap:8px;}
.tip-list li::before{content:'→';color:var(--muted);flex-shrink:0;font-family:'Space Mono',monospace;font-size:0.7rem;margin-top:1px;}

/* scoring panel */
.score-breakdown{display:flex;flex-direction:column;gap:16px;}
.sb-row{background:var(--surface);border:1px solid var(--border);padding:20px 22px;display:flex;gap:20px;align-items:flex-start;}
.sb-weight{font-family:'Bebas Neue',sans-serif;font-size:2.8rem;line-height:1;flex-shrink:0;width:68px;text-align:center;}
.sb-row:nth-child(1) .sb-weight{color:var(--accent);}
.sb-row:nth-child(2) .sb-weight{color:var(--accent3);}
.sb-row:nth-child(3) .sb-weight{color:var(--accent2);}
.sb-info{}
.sb-title{font-weight:600;font-size:0.9rem;margin-bottom:5px;}
.sb-body{font-size:0.82rem;color:var(--muted2);line-height:1.65;}
.sb-formula{font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--accent);background:rgba(245,197,24,0.06);border:1px solid rgba(245,197,24,0.15);padding:8px 12px;margin-top:10px;display:inline-block;letter-spacing:1px;}
.verdict-table{width:100%;border-collapse:collapse;margin-top:20px;}
.verdict-table th{font-family:'Space Mono',monospace;font-size:0.52rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);padding:10px 14px;text-align:left;border-bottom:1px solid var(--border);}
.verdict-table td{font-size:0.82rem;padding:10px 14px;border-bottom:1px solid rgba(28,28,46,0.5);color:var(--muted2);}
.verdict-table tr:last-child td{border-bottom:none;}
.vt-hire{color:var(--accent3);font-weight:600;}
.vt-maybe{color:var(--accent);font-weight:600;}
.vt-pass{color:var(--accent2);font-weight:600;}

/* footer nav */
.guide-footer{display:flex;align-items:center;justify-content:space-between;padding:16px 28px;border-top:1px solid var(--border);flex-shrink:0;}
.guide-step-dots{display:flex;gap:6px;}
.gsd{width:8px;height:8px;border-radius:50%;background:var(--border);cursor:pointer;transition:all 0.2s;}
.gsd.active{background:var(--accent);width:20px;border-radius:4px;}
.guide-nav-btns{display:flex;gap:8px;}
.gnb{background:transparent;border:1px solid var(--border);color:var(--muted);font-family:'Space Mono',monospace;font-size:0.58rem;letter-spacing:1px;text-transform:uppercase;padding:9px 18px;cursor:pointer;transition:all 0.2s;}
.gnb:hover{border-color:var(--text);color:var(--text);}
.gnb.primary{background:var(--accent);border-color:var(--accent);color:#080810;}
.gnb.primary:hover{background:#fff;border-color:#fff;}
</style>
</head>
<body>

<!-- LOBBY -->
<section id="screen-lobby" class="screen active">
  <div class="lobby-wrap">
    <div class="lobby-tag"><span class="pulse"></span> Season 01 · Open Registration</div>
    <h1 class="lobby-title"><span class="t1">Career</span><span class="t2">Arena</span></h1>
    <p class="lobby-sub">Three rounds. One champion. Aptitude quiz, group discussion with AI + crowd scoring, then a live interview judged by both AI and audience.</p>

    <!-- Avatar Picker -->
    <div class="ava-section">
      <div class="ava-heading">Choose Your Avatar</div>
      <div class="ava-grid" id="ava-grid"></div>
    </div>

    <!-- Live Preview Bar -->
    <div class="ava-preview" id="ava-preview">
      <div class="avp-emoji" id="avp-emoji">🎭</div>
      <div class="avp-info">
        <div class="avp-name" id="avp-name">Select an avatar to begin</div>
        <div class="avp-hint">Displayed across all game rounds</div>
      </div>
    </div>

    <div class="name-row">
      <input class="name-input" id="player-name-input" type="text" placeholder="Enter your name to compete..." maxlength="24">
      <button class="btn-enter" onclick="startGame()">Enter Arena →</button>
    </div>
    <div class="lobby-info">
      <div class="li-item"><div class="li-num">40+</div><div class="li-label">Question Bank</div></div>
      <div class="li-item"><div class="li-num">3m</div><div class="li-label">GD Prep</div></div>
      <div class="li-item"><div class="li-num">2x</div><div class="li-label">Dual Scoring</div></div>
      <div class="li-item"><div class="li-num">AI+👥</div><div class="li-label">Both Judges</div></div>
    </div>
  </div>
</section>

<!-- LOADING -->
<section id="screen-loading" class="screen">
  <div class="loading-inner">
    <div class="loading-ring"></div>
    <div class="loading-text" id="loading-text">Preparing Arena</div>
    <div class="loading-sub" id="loading-sub">Setting up your session…</div>
  </div>
</section>

<!-- QUIZ -->
<section id="screen-quiz" class="screen">
  <div class="arena-header">
    <div class="logo">Career<span>Arena</span></div>
    <div class="round-indicator">
      <div class="ri-step active">🧠 Round 1 · Quiz</div>
      <div class="ri-sep">›</div>
      <div class="ri-step">🗣️ Round 2 · GD</div>
      <div class="ri-sep">›</div>
      <div class="ri-step">💼 Round 3 · Interview</div>
    </div>
    <div class="player-badge"><span class="badge-ava" id="hdr-ava-q">🎭</span>Player: <span id="hdr-name-q">—</span></div>
  </div>

  <div class="quiz-layout">
    <!-- Main question area -->
    <div class="quiz-main">
      <div class="quiz-meta">
        <div class="q-progress-wrap">
          <div class="q-progress-label"><span>Progress</span><span id="q-prog-text">1 / 10</span></div>
          <div class="q-progress-bar"><div class="q-progress-fill" id="q-prog-fill" style="width:10%"></div></div>
        </div>
        <div class="q-timer" id="q-timer">
          <svg width="68" height="68" viewBox="0 0 68 68">
            <circle cx="34" cy="34" r="28" fill="none" stroke="#1c1c2e" stroke-width="4"/>
            <circle id="timer-circle" cx="34" cy="34" r="28" fill="none" stroke="#f5c518" stroke-width="4"
              stroke-dasharray="176" stroke-dashoffset="0" stroke-linecap="round" style="transition:stroke-dashoffset 1s linear"/>
          </svg>
          <div class="q-timer-text" id="q-timer-text">25</div>
        </div>
      </div>
      <div class="q-card">
        <div class="q-number" id="q-number">QUESTION 01</div>
        <div class="q-text" id="q-text">Loading…</div>
        <div class="q-options" id="q-options"></div>
      </div>
      <div class="q-feedback" id="q-feedback"></div>
      <div class="q-footer">
        <div class="q-score-mini">Score: <span id="live-score">0</span> correct</div>
        <button class="btn-next" id="btn-next" disabled onclick="nextQuestion()">Next →</button>
      </div>
    </div>

    <!-- Live Scoreboard Sidebar -->
    <div class="quiz-sidebar">
      <div class="sb-title">
        Live Scoreboard
        <span class="sb-qcount" id="sb-qcount">Q0 of 10</span>
      </div>
      <div class="sb-players" id="sb-players"></div>
      <div class="sb-divider"></div>
      <div class="sb-stat-row">
        <span class="sb-stat-lbl">Top Score</span>
        <span class="sb-stat-val hi" id="sb-top-score">—</span>
      </div>
      <div class="sb-stat-row">
        <span class="sb-stat-lbl">Your Rank</span>
        <span class="sb-stat-val" id="sb-your-rank">—</span>
      </div>
      <div class="sb-stat-row">
        <span class="sb-stat-lbl">Gap to Lead</span>
        <span class="sb-stat-val lo" id="sb-gap">—</span>
      </div>
    </div>
  </div>
</section>

<!-- QUIZ RESULT -->
<section id="screen-quiz-result" class="screen">
  <div class="result-card" id="quiz-result-card">
    <span class="result-icon" id="result-icon">🎯</span>
    <div class="result-title" id="result-title">QUALIFIED!</div>
    <div class="result-score" id="result-score">7<sub>/10</sub></div>
    <p class="result-sub" id="result-sub">Strong result! You're heading to the Group Discussion.</p>
    <button class="result-btn" id="result-main-btn" onclick="proceedFromResult()">Continue →</button>
    <button class="result-btn ghost" onclick="restartGame()">← Start Over</button>
  </div>
</section>

<!-- JUDGE (eliminated) -->
<section id="screen-judge" class="screen">
  <div class="judge-wrap">
    <span class="judge-icon">⚖️</span>
    <div class="judge-title">You're The Judge</div>
    <p class="judge-sub">Your quiz score didn't make the cut — but your vote still shapes who advances. Head to the Group Discussion and vote for the best speaker.</p>
    <button class="judge-btn" onclick="loadGD()">Watch Group Discussion →</button>
  </div>
</section>

<!-- GD -->
<section id="screen-gd" class="screen">
  <div class="arena-header">
    <div class="logo">Career<span>Arena</span></div>
    <div class="round-indicator">
      <div class="ri-step done">✓ Round 1</div>
      <div class="ri-sep">›</div>
      <div class="ri-step active">🗣️ Round 2 · GD</div>
      <div class="ri-sep">›</div>
      <div class="ri-step">💼 Round 3</div>
    </div>
    <div class="player-badge"><span class="badge-ava" id="hdr-ava-gd">🎭</span>Player: <span id="hdr-name-gd">—</span></div>
  </div>
  <div class="gd-body">
    <div class="gd-main">
      <div class="gd-topic-reveal">
        <div class="gd-topic-label">Today's GD Topic</div>
        <div class="gd-topic-text" id="gd-topic">—</div>
      </div>
      <div class="gd-phase">
        <div class="phase-badge prep" id="phase-badge">⏳ PREP PHASE</div>
        <div class="phase-desc" id="phase-desc">Organise your thoughts and key arguments.</div>
      </div>
      <div class="gd-timer-big">
        <div class="gd-timer-num" id="gd-timer-num">1:00</div>
        <div class="gd-timer-label" id="gd-timer-label">Preparation Time</div>
      </div>
      <div class="section-lbl">📝 Your Preparation Notes</div>
      <textarea class="gd-notes" id="gd-notes" placeholder="Jot down key arguments, examples, counter-points…"></textarea>
      <div class="gd-action-row">
        <button class="btn-speak" id="btn-speak" disabled onclick="startSpeaking()">🎤 Start My Speech (60s)</button>
      </div>
      <div id="gd-speech-area" style="display:none;margin-top:18px;">
        <div class="section-lbl">💬 Your Speech (60 seconds)</div>

        <!-- Voice toggle -->
        <div class="voice-toggle-row">
          <button class="voice-toggle-pill" id="gd-voice-toggle" onclick="toggleVoiceMode('gd')">
            <span class="vtp-dot"></span>🎙️ Use Voice Instead
          </button>
          <span style="font-size:0.75rem;color:var(--muted)">speak your speech aloud</span>
        </div>

        <!-- Voice notice -->
        <div class="voice-mode-notice" id="gd-voice-notice">
          🎙️ <strong>Voice Mode ON</strong> — Click the mic, speak your speech, then click Stop. Your words appear below automatically.
        </div>

        <textarea class="gd-notes" id="gd-speech-input" placeholder="Type your speech… or use the 🎙️ mic below" style="min-height:110px;border-color:var(--accent3)"></textarea>

        <!-- Voice bar -->
        <div class="voice-bar" id="gd-voice-bar" style="display:none;">
          <span class="voice-bar-label">🎤 MIC</span>
          <button class="mic-btn" id="gd-mic-btn" onclick="toggleGDMic()" title="Start/Stop Recording">🎤</button>
          <div class="voice-wave" id="gd-wave">
            <div class="vw-bar" style="height:8px"></div><div class="vw-bar" style="height:14px"></div>
            <div class="vw-bar" style="height:6px"></div><div class="vw-bar" style="height:18px"></div>
            <div class="vw-bar" style="height:10px"></div><div class="vw-bar" style="height:20px"></div>
            <div class="vw-bar" style="height:8px"></div><div class="vw-bar" style="height:14px"></div>
            <div class="vw-bar" style="height:16px"></div><div class="vw-bar" style="height:6px"></div>
            <div class="vw-bar" style="height:12px"></div><div class="vw-bar" style="height:18px"></div>
          </div>
          <div class="voice-status" id="gd-voice-status">Ready</div>
        </div>

        <div class="gd-action-row">
          <button class="btn-speak" id="btn-submit-speech" onclick="submitSpeech()" style="background:var(--accent);color:#080810">Submit Speech ✓</button>
        </div>
      </div>
      <!-- DUAL SCORE PANEL GD -->
      <div class="dual-score-panel" id="gd-dual-panel" style="display:none">
        <div class="dsp-title">📊 GD Live Scoring — AI Judge + Audience</div>
        <div class="dsp-grid">
          <div class="dsp-half">
            <div class="dsp-half-title ai-title">🤖 AI Judge Score</div>
            <div id="ai-gd-scores"></div>
          </div>
          <div class="dsp-half">
            <div class="dsp-half-title aud-title">👥 Audience Score</div>
            <div id="aud-gd-scores"></div>
          </div>
        </div>
        <div id="gd-combined-scores" style="margin-top:10px;"></div>
      </div>
    </div>
    <div class="gd-sidebar">
      <div class="sidebar-section">
        <div class="sidebar-title">Players in GD</div>
        <div class="player-list" id="gd-player-list"></div>
      </div>
      <div class="sidebar-section" id="speeches-section" style="display:none">
        <div class="sidebar-title">Speeches Delivered</div>
        <div id="speeches-list"></div>
      </div>
      <div class="sidebar-section" id="vote-section" style="display:none">
        <div class="sidebar-title">🗳️ Your Audience Vote</div>
        <div id="vote-cards"></div>
      </div>
    </div>
  </div>
</section>

<!-- INTERVIEW -->
<section id="screen-interview" class="screen">
  <div class="arena-header">
    <div class="logo">Career<span>Arena</span></div>
    <div class="round-indicator">
      <div class="ri-step done">✓ Round 1</div>
      <div class="ri-sep">›</div>
      <div class="ri-step done">✓ Round 2</div>
      <div class="ri-sep">›</div>
      <div class="ri-step active">💼 Round 3 · Interview</div>
    </div>
    <div class="player-badge"><span class="badge-ava" id="hdr-ava-iv">🎭</span>Player: <span id="hdr-name-iv">—</span></div>
  </div>
  <div class="interview-body">
    <div class="interview-main">
      <div class="interview-q-card">
        <div class="iq-meta">
          <div class="iq-label" id="iv-q-label">Question 1 of 3</div>
          <div class="iq-category" id="iv-q-cat">HR</div>
        </div>
        <div class="iq-text" id="iv-q-text">Loading…</div>
      </div>
      <div class="section-lbl">✍️ Your Answer</div>

      <!-- Voice toggle for interview -->
      <div class="voice-toggle-row">
        <button class="voice-toggle-pill iv-pill" id="iv-voice-toggle" onclick="toggleVoiceMode('iv')">
          <span class="vtp-dot"></span>🎙️ Speak Your Answer
        </button>
        <span style="font-size:0.75rem;color:var(--muted)">use your voice to answer</span>
      </div>

      <!-- Voice notice -->
      <div class="voice-mode-notice iv-notice" id="iv-voice-notice">
        🎙️ <strong>Voice Mode ON</strong> — Click the mic and speak your answer. The AI interviewer will also read the question aloud to you.
      </div>

      <textarea class="answer-textarea" id="iv-answer" placeholder="Type your answer here… or use the 🎙️ mic below"></textarea>

      <!-- Voice bar for interview -->
      <div class="voice-bar iv-voice" id="iv-voice-bar" style="display:none;">
        <span class="voice-bar-label">🎤 MIC</span>
        <button class="mic-btn iv-mic" id="iv-mic-btn" onclick="toggleIVMic()" title="Start/Stop Recording">🎤</button>
        <div class="voice-wave" id="iv-wave">
          <div class="vw-bar" style="height:8px"></div><div class="vw-bar" style="height:14px"></div>
          <div class="vw-bar" style="height:6px"></div><div class="vw-bar" style="height:18px"></div>
          <div class="vw-bar" style="height:10px"></div><div class="vw-bar" style="height:20px"></div>
          <div class="vw-bar" style="height:8px"></div><div class="vw-bar" style="height:14px"></div>
          <div class="vw-bar" style="height:16px"></div><div class="vw-bar" style="height:6px"></div>
          <div class="vw-bar" style="height:12px"></div><div class="vw-bar" style="height:18px"></div>
        </div>
        <div class="voice-status" id="iv-voice-status">Ready</div>
      </div>

      <!-- AI speaking chip -->
      <div class="ai-speaking-chip" id="ai-speaking-chip">
        <div class="ai-wave"><span></span><span></span><span></span><span></span><span></span></div>
        AI Interviewer Speaking…
      </div>

      <div id="iv-review-area"></div>
      <div class="interview-footer">
        <div class="q-counter">Question <span id="iv-q-num">1</span> of 3</div>
        <button class="btn-submit-iv" id="btn-submit-iv" onclick="submitAnswer()">Submit Answer →</button>
      </div>
    </div>
    <div class="interview-sidebar">
      <div class="sidebar-section">
        <div class="sidebar-title">Live Scores</div>
        <div class="iv-dual-panel" id="iv-dual-panel">
          <div class="iv-score-tabs">
            <div class="iv-tab ai-tab">
              <div class="iv-tab-label">🤖 AI Judge</div>
              <div class="iv-tab-score" id="iv-ai-score">—</div>
            </div>
            <div class="iv-tab aud-tab">
              <div class="iv-tab-label">👥 Audience</div>
              <div class="iv-tab-score" id="iv-aud-score">—</div>
            </div>
          </div>
          <div class="iv-combined-score">
            <div class="iv-comb-label">Combined Score</div>
            <div class="iv-comb-num" id="iv-comb-num">—</div>
            <div id="iv-comb-verdict"></div>
          </div>
        </div>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-title">Audience Reactions</div>
        <div id="audience-vote-list"></div>
      </div>
    </div>
  </div>
</section>

<!-- FINAL -->
<section id="screen-final" class="screen">
  <div class="final-wrap">
    <span class="trophy">🏆</span>
    <div class="final-title">Champion!</div>
    <div class="final-name" id="final-winner-name">—</div>
    <div class="final-podium" id="final-podium"></div>
    <button class="play-again-btn" onclick="restartGame()">⟳ Play Again</button>
  </div>
</section>

<!-- GUIDE FAB -->
<button class="guide-fab" onclick="openGuide()" title="How to Play">
  <span class="gf-icon">📖</span> How to Play
</button>

<!-- GUIDE OVERLAY -->
<div class="guide-overlay" id="guide-overlay">
  <div class="guide-backdrop" onclick="closeGuide()"></div>
  <div class="guide-modal">

    <!-- Header -->
    <div class="guide-header">
      <div class="guide-header-left">
        <div class="guide-eyebrow">Game Guide</div>
        <div class="guide-title">How Career Arena Works</div>
      </div>
      <button class="guide-close" onclick="closeGuide()">✕</button>
    </div>

    <!-- Tabs -->
    <div class="guide-tabs">
      <button class="guide-tab active" onclick="switchGuideTab(0)" id="gtab-0">
        <span class="gt-icon">🗺️</span>Overview
      </button>
      <button class="guide-tab" onclick="switchGuideTab(1)" id="gtab-1">
        <span class="gt-icon">🧠</span>Round 1
      </button>
      <button class="guide-tab" onclick="switchGuideTab(2)" id="gtab-2">
        <span class="gt-icon">🗣️</span>Round 2
      </button>
      <button class="guide-tab" onclick="switchGuideTab(3)" id="gtab-3">
        <span class="gt-icon">💼</span>Round 3
      </button>
      <button class="guide-tab" onclick="switchGuideTab(4)" id="gtab-4">
        <span class="gt-icon">📊</span>Scoring
      </button>
      <button class="guide-tab" onclick="switchGuideTab(5)" id="gtab-5">
        <span class="gt-icon">💡</span>Tips
