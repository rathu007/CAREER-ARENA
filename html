const SB_AI = [
  { name:'Arjun M.',  color:'#f5c518', emoji:'🧑' },
  { name:'Priya K.',  color:'#00e5a0', emoji:'👩' },
  { name:'Rahul S.',  color:'#4d9fff', emoji:'🧑' },
];
let sbScores = []; // [{name,emoji,color,score,isYou}]
let sbPrevRanks = {};

function initScoreboard(){
  sbScores = [
    { name: S.playerName, emoji: S.playerAvatar||'🎭', color:'#f5c518', score:0, isYou:true },
    ...SB_AI.map(a=>({ ...a, score:0, isYou:false }))
  ];
  sbPrevRanks = {};
  sbScores.forEach((p,i)=>{ sbPrevRanks[p.name]=i; });
  renderScoreboard();
}

function tickAIScores(playerGotRight){
  // AI gets each Q right with ~55% chance; slightly higher if player got it wrong
  const chance = playerGotRight ? 0.50 : 0.62;
  sbScores.forEach(p=>{ if(!p.isYou && Math.random() < chance) p.score++; });
}

function renderScoreboard(){
  const total = S.quizQs.length || 10;
  const answered = S.currentQ;

  // sort by score desc, stable: keep original order for ties
  const sorted = [...sbScores].sort((a,b)=> b.score - a.score || (a.isYou?-1:1));
  const leader = sorted[0];

  document.getElementById('sb-qcount').textContent = `Q${answered} of ${total}`;
  document.getElementById('sb-top-score').textContent = `${leader.score}/${answered}`;

  const youEntry = sorted.find(p=>p.isYou);
  const yourRank = sorted.indexOf(youEntry)+1;
  document.getElementById('sb-your-rank').textContent = `#${yourRank} of ${sorted.length}`;

  const gap = leader.score - (youEntry?.score||0);
  const gapEl = document.getElementById('sb-gap');
  gapEl.textContent = gap===0 ? 'Leading! 🔥' : `−${gap} pts`;
  gapEl.className = `sb-stat-val ${gap===0?'hi':'lo'}`;

  const container = document.getElementById('sb-players');
  container.innerHTML = sorted.map((p,i)=>{
    const rank = i+1;
    const rankClass = rank===1?'r1':rank===2?'r2':rank===3?'r3':'';
    const isLeader = rank===1;
    const barPct = answered>0 ? Math.round((p.score/answered)*100) : 0;
    const prevRank = sbPrevRanks[p.name] ?? i;
    const climbed = rank < prevRank;
    const delta = prevRank - rank; // positive = climbed up
    const deltaHtml = answered>0
      ? `<span class="sb-delta ${delta>0?'up':'same'}">${delta>0?'↑'+delta:'—'}</span>`
      : '';
    return `<div class="sb-row${p.isYou?' is-you':''}${isLeader?' is-leader':''}${climbed?' climbed':''}" id="sbr-${p.name.replace(/\W/g,'_')}">
      ${isLeader?'<span class="sb-crown">👑</span>':''}
      <div class="sb-row-top">
        <span class="sb-rank ${rankClass}">${rank}</span>
        <span class="sb-avatar">${p.emoji}</span>
        <div class="sb-info">
          <div class="sb-name${p.isYou?' you-tag':''}">${p.name}${deltaHtml}</div>
        </div>
        <span class="sb-pts${isLeader?' leader-pts':''}">${p.score}</span>
      </div>
      <div class="sb-bar-wrap">
        <div class="sb-bar" style="background:${p.color};width:${barPct}%"></div>
      </div>
    </div>`;
  }).join('');

  // Update prev ranks for next render
  sorted.forEach((p,i)=>{ sbPrevRanks[p.name]=i; });
}

