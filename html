// ════════════════════════════════════════════
function prepareQuiz(){
  // Pick 10 random questions (2-3 per category)
  const cats = ['Logical Reasoning','Numerical','Verbal Ability','General Knowledge'];
  let picked = [];
  cats.forEach(cat=>{
    const pool = QUESTION_BANK.filter(q=>q.cat===cat);
    const shuffled = pool.sort(()=>Math.random()-0.5);
    picked.push(...shuffled.slice(0, cat==='Logical Reasoning'||cat==='Numerical'?3:2));
  });
  // Fill remaining from all
  const remaining = QUESTION_BANK.filter(q=>!picked.includes(q)).sort(()=>Math.random()-0.5);
  while(picked.length<10) picked.push(remaining[picked.length-10] || remaining[0]);
  S.quizQs = picked.slice(0,10).sort(()=>Math.random()-0.5);
  S.currentQ=0; S.score=0;
  initScoreboard();
  renderQuestion();
  startQuizTimer();
}

function renderQuestion(){
  const q = S.quizQs[S.currentQ];
  document.getElementById('q-number').textContent=`QUESTION ${String(S.currentQ+1).padStart(2,'0')} · ${q.cat.toUpperCase()}`;
  document.getElementById('q-text').textContent=q.q;
  document.getElementById('q-prog-text').textContent=`${S.currentQ+1} / ${S.quizQs.length}`;
  document.getElementById('q-prog-fill').style.width=`${((S.currentQ+1)/S.quizQs.length)*100}%`;
  document.getElementById('q-feedback').className='q-feedback';
  document.getElementById('q-feedback').textContent='';
  document.getElementById('btn-next').disabled=true;
  document.getElementById('live-score').textContent=S.score;
  const opts = document.getElementById('q-options');
  opts.innerHTML = q.options.map((opt,i)=>
    `<button class="q-option" onclick="selectAnswer(${i})"><span class="q-option-letter">${['A','B','C','D'][i]}.</span>${opt}</button>`
  ).join('');
}

let timerVal=25;
function startQuizTimer(){
  clearInterval(S.timerInterval); timerVal=25; updateTimerUI();
  S.timerInterval=setInterval(()=>{
    timerVal--;updateTimerUI();
    if(timerVal<=5)document.getElementById('q-timer').classList.add('urgent');
    else document.getElementById('q-timer').classList.remove('urgent');
    if(timerVal<=0){clearInterval(S.timerInterval);autoAdvance();}
  },1000);
}
function updateTimerUI(){
  document.getElementById('q-timer-text').textContent=timerVal;
  document.getElementById('timer-circle').style.strokeDashoffset=176*(1-timerVal/25);
}
function autoAdvance(){
  const q=S.quizQs[S.currentQ];
  const fb=document.getElementById('q-feedback');
  fb.className='q-feedback wrong-fb';
  fb.textContent=`⏱ Time's up! Correct: ${['A','B','C','D'][q.answer]}. ${q.explanation}`;
  document.querySelectorAll('.q-option').forEach(b=>b.disabled=true);
  document.querySelectorAll('.q-option')[q.answer].classList.add('correct');
  // timed out = player got it wrong
  tickAIScores(false);
  renderScoreboard();
  document.getElementById('btn-next').disabled=false;
}
function selectAnswer(idx){
  clearInterval(S.timerInterval);
  const q=S.quizQs[S.currentQ];
  const btns=document.querySelectorAll('.q-option');
  btns.forEach(b=>b.disabled=true);
  const fb=document.getElementById('q-feedback');
  const gotRight = idx===q.answer;
  if(gotRight){S.score++;btns[idx].classList.add('correct');fb.className='q-feedback correct-fb';fb.textContent=`✓ Correct! ${q.explanation}`;}
  else{btns[idx].classList.add('wrong');btns[q.answer].classList.add('correct');fb.className='q-feedback wrong-fb';fb.textContent=`✗ Incorrect. Correct: ${['A','B','C','D'][q.answer]}. ${q.explanation}`;}
  document.getElementById('live-score').textContent=S.score;
  // update player score in scoreboard
  const me = sbScores.find(p=>p.isYou);
  if(me) me.score = S.score;
  tickAIScores(gotRight);
  renderScoreboard();
  document.getElementById('btn-next').disabled=false;
}
function nextQuestion(){
  S.currentQ++;
  if(S.currentQ>=S.quizQs.length){endQuiz();}
  else{renderQuestion();startQuizTimer();}
}
function endQuiz(){
  clearInterval(S.timerInterval);
  S.passed=S.score>=5;
  const card=document.getElementById('quiz-result-card');
  card.className=`result-card ${S.passed?'pass':'fail'}`;
  document.getElementById('result-icon').textContent=S.passed?'🎯':'💔';
  document.getElementById('result-title').textContent=S.passed?'QUALIFIED!':'ELIMINATED';
  document.getElementById('result-score').innerHTML=`${S.score}<sub>/10</sub>`;
  document.getElementById('result-sub').textContent=S.passed
    ?`You scored ${S.score}/10! You've earned a spot in the Group Discussion.`
    :`You scored ${S.score}/10. You needed 5 to advance. But your audience vote still matters in GD and Interview!`;
  const btn=document.getElementById('result-main-btn');
  btn.textContent=S.passed?'Continue to Group Discussion →':'Become an Audience Judge →';
  showScreen('screen-quiz-result');
}
function proceedFromResult(){ if(S.passed){loadGD();}else{showScreen('screen-judge');} }

